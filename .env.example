# ─────────────────────────────────────────────────────────────────────────────
# Histyon — Environment Variables
# Copy this file to .env.local and fill in the values.
# NEVER commit .env.local to git.
# ─────────────────────────────────────────────────────────────────────────────

# ── Supabase ──────────────────────────────────────────────────────────────────
# Found in: Supabase Dashboard → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ── App URL ───────────────────────────────────────────────────────────────────
# Used to build absolute URLs (email links, auth callbacks).
# Local: http://localhost:3000 — Production: https://yourdomain.com
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# ── Resend (transactional email) ──────────────────────────────────────────────
# https://resend.com/api-keys
RESEND_API_KEY=re_your_key_here
# The verified sender address configured in Resend
RESEND_FROM_EMAIL=noreply@yourdomain.com
# Admin email to receive new doctor registration notifications
ADMIN_EMAIL=admin@yourdomain.com

# ── Webhook secrets ───────────────────────────────────────────────────────────
# SUPABASE_HOOK_SECRET: generated when adding a Supabase Auth hook
# Format: v1,whsec_<base64> — copy from Supabase Dashboard → Auth → Hooks
SUPABASE_HOOK_SECRET=v1,whsec_your_hook_secret_here

# WEBHOOK_SECRET: shared secret with the AI job worker
# Any random string, must match what the worker sends
WEBHOOK_SECRET=your_random_webhook_secret_here

# ── Vercel KV (Redis — rate limiting + profile cache) ────────────────────────
# Automatically set when you link a KV store in Vercel Dashboard.
# For local dev these are optional — falls back to in-memory rate limiting.
KV_REST_API_URL=https://your-kv-url.upstash.io
KV_REST_API_TOKEN=your-kv-token

# ── Admin API tokens (ops console only — never exposed to browser) ────────────
# Vercel API token for the ops console metrics page
ADMIN_VERCEL_TOKEN=your_vercel_token
VERCEL_PROJECT_ID=your_vercel_project_id
VERCEL_TEAM_ID=your_vercel_team_id

# Supabase Management API token for the ops console DB stats page
ADMIN_SUPABASE_MANAGEMENT_TOKEN=sbp_your_management_token
SUPABASE_PROJECT_REF=your-project-ref
